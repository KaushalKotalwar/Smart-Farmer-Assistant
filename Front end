<script>

let lastSpokenText = "";
let currentLang = "en";

function speakResult() {

    if (!lastSpokenText) {
        alert("No result to speak");
        return;
    }

    let speech = new SpeechSynthesisUtterance(lastSpokenText);

    // 🌍 SET LANGUAGE
    if (currentLang === "mr") {
        speech.lang = "mr-IN";
    } 
    else if (currentLang === "hi") {
        speech.lang = "hi-IN";
    } 
    else {
        speech.lang = "en-US";
    }

    speech.rate = 1;
    speech.pitch = 1;

    window.speechSynthesis.speak(speech);
}

// 🌍 LABEL TRANSLATIONS
const uiText = {
    en: {
        title: "🌱 Smart Farmer Assistant",
        detect: "🧪 Plant Disease Detection",
        tips: "🌾 Smart Herbal Farming Tips",
        detecting: "Detecting disease..."
    },
    mr: {
        title: "🌱 स्मार्ट शेतकरी सहाय्यक",
        detect: "🧪 रोग शोध",
        tips: "🌾 शेती टिप्स",
        detecting: "रोग तपासला जात आहे..."
    },
    hi: {
        title: "🌱 स्मार्ट किसान सहायक",
        detect: "🧪 रोग पहचान",
        tips: "🌾 खेती सुझाव",
        detecting: "रोग की जांच हो रही है..."
    }
};

// 🌍 CHANGE LANGUAGE
function setLang(lang) {
    currentLang = lang;

    document.getElementById("title").innerText = uiText[lang].title;
    document.getElementById("detectTitle").innerText = uiText[lang].detect;
    document.getElementById("tipsTitle").innerText = uiText[lang].tips;
}

// 🌟 RESULT DISPLAY
function showResult(data) {

    let t = uiText[currentLang];
    let box = document.getElementById("result");

    box.style.display = "block";
    box.innerHTML = t.detecting;

    setTimeout(() => {

        let text = `
        ${data.disease}.
        ${data.cause || ""}.
        ${data.chemical}.
        ${data.herbal}.
        ${data.prevention}.
        Severity ${data.severity}.
        `;

        lastSpokenText = text; // ✅ SAVE FOR VOICE

        box.innerHTML = `
        <b>🌿 ${data.disease}</b><br>
        <b>📊 ${data.severity}</b><br>
        <b>⚠ ${data.cause || "-"}</b><br><br>

        🧪 ${data.chemical}<br>
        🔗 <a href="${data.link}" target="_blank">Link</a><br><br>

        🌿 ${data.herbal}<br>
        🛡 ${data.prevention}
        `;

    }, 1000);
}

// 🔍 SYMPTOM
function detect(){
let s=document.getElementById("symptom").value;

fetch("http://127.0.0.1:5000/api/symptom",{
method:"POST",
headers:{"Content-Type":"application/json"},
body: JSON.stringify({
    symptom: s,
    lang: currentLang   // 🔥 IMPORTANT
})
})
.then(r=>r.json())
.then(d=>{
    showResult(d);
});
}

// 📷 IMAGE
function upload(){
let f=document.getElementById("image").files[0];

if(!f){alert("Select image");return;}

let fd=new FormData();
fd.append("image",f);

fetch("http://127.0.0.1:5000/api/predict",{
method:"POST",
body:fd
})
.then(r=>r.json())
.then(d=>{
    showResult(d);
});
}

// IMAGE PREVIEW
function previewImage(event) {
    let file = event.target.files[0];
    let reader = new FileReader();

    reader.onload = function() {
        let img = document.getElementById("preview");
        img.src = reader.result;
        img.style.display = "block";
    };

    reader.readAsDataURL(file);
}

</script>

